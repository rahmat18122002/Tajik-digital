rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'aliali18122002@gmail.com' && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'categoryId', 'techStack', 'description', 'longDescription', 'features', 'image', 'fallbackImage'])
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 200
        && data.categoryId is string && data.categoryId.size() <= 50
        && data.techStack is list && data.techStack.size() <= 100
        && data.description is string && data.description.size() <= 5000
        && data.longDescription is string && data.longDescription.size() <= 10000
        && data.features is list && data.features.size() <= 100
        && data.image is string && data.image.size() <= 1000000
        && data.fallbackImage is string && data.fallbackImage.size() <= 1000000;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'benefits', 'icon', 'glowColor'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.benefits is list && data.benefits.size() <= 100
        && data.icon is string && data.icon.size() <= 1000000
        && data.glowColor is string && data.glowColor.size() <= 50;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'position', 'company', 'rating', 'feedback', 'gender'])
        && data.name is string && data.name.size() <= 200
        && data.position is string && data.position.size() <= 200
        && data.company is string && data.company.size() <= 200
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.feedback is string && data.feedback.size() <= 5000
        && data.gender is string && data.gender.size() <= 20;
    }

    function isValidStats(data) {
      return data.keys().hasAll(['projectsCount', 'experienceYears', 'clientsSatisfaction', 'miniAppsCreated'])
        && data.projectsCount is number
        && data.experienceYears is number
        && data.clientsSatisfaction is number
        && data.miniAppsCreated is number;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'role', 'introTitle', 'bio', 'quote', 'avatarUrl', 'telegram', 'whatsapp', 'github', 'websiteName'])
        && data.name is string && data.name.size() <= 200
        && data.role is string && data.role.size() <= 200
        && data.introTitle is string && data.introTitle.size() <= 500
        && data.bio is string && data.bio.size() <= 5000
        && data.quote is string && data.quote.size() <= 5000
        && data.avatarUrl is string && data.avatarUrl.size() <= 1000000
        && data.telegram is string && data.telegram.size() <= 200
        && data.whatsapp is string && data.whatsapp.size() <= 200
        && data.github is string && data.github.size() <= 200
        && data.websiteName is string && data.websiteName.size() <= 200
        && (!data.keys().hasAny(['logoUrl']) || (data.logoUrl is string && data.logoUrl.size() <= 1000000));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'contactHandle', 'serviceType', 'message', 'timestamp', 'status'])
        && data.name is string && data.name.size() <= 200
        && data.contactHandle is string && data.contactHandle.size() <= 200
        && data.serviceType is string && data.serviceType.size() <= 200
        && data.message is string && data.message.size() <= 5000
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.status is string && data.status.size() <= 50;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow delete: if isAdmin() && isValidId(projectId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow delete: if isAdmin() && isValidId(serviceId);
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
      allow update: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
      allow delete: if isAdmin() && isValidId(testimonialId);
    }

    match /global/stats {
      allow read: if true;
      allow create: if isAdmin() && isValidStats(incoming());
      allow update: if isAdmin() && isValidStats(incoming());
      allow delete: if false; // Only one document, never delete, just update
    }

    match /global/profile {
      allow read: if true;
      allow create: if isAdmin() && isValidProfile(incoming());
      allow update: if isAdmin() && isValidProfile(incoming());
      allow delete: if false; // Only one document
    }

    match /messages/{messageId} {
      allow read: if isAdmin(); // only admin can read messages
      allow create: if isValidId(messageId) && isValidMessage(incoming()); // anyone can submit contact form
      allow update: if isAdmin() && isValidId(messageId) && isValidMessage(incoming()); // admin changes status
      allow delete: if isAdmin() && isValidId(messageId);
    }
  }
}
